# Copy to .env.local for development. On Vercel, set these in Project → Settings → Environment Variables.

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only — never expose in client code or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Dashboard login (use strong values in production; prefer ADMIN_* over NEXT_PUBLIC_*)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-to-a-long-random-secret

# Optional legacy fallbacks (not recommended — secrets would be bundled if prefixed NEXT_PUBLIC_)
# NEXT_PUBLIC_ADMIN_EMAIL=
# NEXT_PUBLIC_ADMIN_PASSWORD=
